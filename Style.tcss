Screen {
    background: rgb(214, 214, 214);
    color: white;
    align: center middle;
}

Footer {
    background: black;
}

#vg_botoes {
    border: none;
}

#vg_botoes Button{
    margin: 0;  
    height: 60%;
    width: 100%;
    min-width: 0;
    min-height: 0;
    border: tall 10% black;   
}

Select { 
    width: 22%;
}


#hg_arquivos {
    width: 100%;
    background: black 50%;
    height: auto;
    margin: 0 2 1 2;
    overflow: auto auto;
}

#hg_arquivos Static {
    width: auto;
    height: auto;
    border: 10% black;
}

#hg_arquivos Static:hover {
    background: red 20%;
}

#data {
    dock: bottom;
    width: 100%;
    height: 5%;
    background: black 50%;
    content-align: center middle;
    align: center middle;
}

#data Static {
    width: auto;
    height: auto;
    color: black;
    text-align: center;
}

#hg_editar_arquivos {
    content-align: center middle;
    margin-left: 2;
}

#hg_editar_arquivos Static{
    color: black;
    margin-bottom: 1;
}

#bot {
    background: black 25%;
    margin: 2;
    border:  tall 40% black;
}

#bot .user {
    text-align: right;
    margin-bottom: 1;
    border: 5% black;
    margin: 0 2 1 2;
    color: black;
}

#bot Static {
    margin: 0 2 1 2;
    border: 5% black;
    width: 100%;
    color: black;
}

#hg_bot {
    height: 90%;
    margin: 2;
}

#hg_user {
    height: 20%;
    dock: bottom;
    margin: 0 2 3 2;
    width: 100%;
    content-align: center middle;
    # border:  tall 10% black;
}

VerticalGroup {
    height: 100%;
    width: 8%;
}

#h_top {
    margin: 1 2 0 2;
    height: auto;
}

#h_top Input{
  width: auto;
  min-width: 20%;
}

ColorPicker {
    height: 100%;
    width: 38%;
    layout: horizontal;

    VerticalGroup:first-child {
        width: 100%;
        height: 100%;
        layout: horizontal;
        overflow: auto auto;
    }

    SaturationValuePicker {
        width: 50%;
    }

    HuePicker {
        width: 50%;
        margin: 1 0 0 1;
    }

    ColorPreview {
        display: none;
    }

    ColorInputs {
        display: none;
    }

}


App.tamanho-34 {
    #user {
        width: 50%;
    }
    #hg_editar_arquivos {
        width: 28%;
    }
    #vg_botoes {
        width: 24%;
    }
    Select {
        width: 70%;
    }
    Footer {
        # background: green;
    }
}

App.tamanho-64 {
    #user {
        width: 67%;
    }
    #hg_editar_arquivos {
        width: 14%;
    }
    #vg_botoes {
        width: 17%;
    }
    Select {
        width: 35%;
    }
    Footer {
        # background: purple;
    }
}

App.tamanho-98 {
    #user {
        width: 72%;
    }
    #hg_editar_arquivos {
        width: 14%;
    }
    #vg_botoes {
        width: 15%;
    }
    Select {
        width: 30%;
    }
    Footer {
        # background: orange;
    }
}